import pandas as pd
from prophet import Prophet

# Load data

df = pd.read_csv('../data/processed/bed_demand.csv')

# Prophet format

df = df.rename(columns={
    'date': 'ds',
    'bed_occupancy': 'y'
})

# Train model

model = Prophet()
model.fit(df)

# Future prediction

future = model.make_future_dataframe(periods=7)
forecast = model.predict(future)

# Save output

forecast[['ds', 'yhat']].to_csv(
    '../data/sample_output/next_week_forecast.csv',
    index=False
)

print(forecast[['ds', 'yhat']].tail())
